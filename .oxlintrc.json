{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "react-perf", "jsx-a11y", "import", "node", "promise"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn",
    "style": "off",
    "pedantic": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "no-console": "off",
    "react/react-in-jsx-scope": "off",
    "react/no-unknown-property": "off",
    "import/no-unassigned-import": "off",
    "jsx-a11y/prefer-tag-over-role": "off",
    "jsx-a11y/heading-has-content": "off"
  },
  "ignorePatterns": [
    ".next",
    "node_modules",
    "coverage",
    "playwright-report",
    "test-results",
    "public",
    "wordpress-export",
    "content/services/*.mdx",
    "content/pages/*.mdx"
  ]
}
