# Required: contact form submissions go through Web3Forms (https://web3forms.com)
# Get an access key at web3forms.com — add it as a Vercel secret named WEB3FORMS_ACCESS_KEY
WEB3FORMS_ACCESS_KEY=
NEXT_PUBLIC_SITE_URL=https://acutabovelawncareinc.ca

# PostHog UX monitoring. Leave blank to disable.
NEXT_PUBLIC_POSTHOG_KEY=
# Set to your reverse proxy domain (e.g. https://p.acutabovelawncareinc.ca)
# Falls back to https://us.i.posthog.com if not set
NEXT_PUBLIC_POSTHOG_HOST=
